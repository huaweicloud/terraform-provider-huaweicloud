{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_taurusdb_eip_associate": {
          "block": {
            "attributes": {
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_id": {
                "type": "string",
                "description": "Specifies the ID of a TaurusDB instance.",
                "required": true,
                "forcenew": true
              },
              "public_ip": {
                "type": "string",
                "description": "Specifies the EIP address to be bound.",
                "required": true,
                "forcenew": true
              },
              "public_ip_id": {
                "type": "string",
                "description": "Specifies the ID of the EIP.",
                "required": true,
                "forcenew": true
              },
              "region": {
                "type": "string",
                "computed": true
              }
            }
          }
        }
      }
    }
  }
}
