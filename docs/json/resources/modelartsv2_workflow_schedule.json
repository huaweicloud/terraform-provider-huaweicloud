{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_modelartsv2_workflow_schedule": {
          "block": {
            "attributes": {
              "content": {
                "type": "string",
                "description": "The content of the workflow schedule, in JSON format.",
                "required": true
              },
              "created_at": {
                "type": "string",
                "description": "The creation time of the workflow schedule, in RFC3339 format.",
                "computed": true
              },
              "enable": {
                "type": "bool",
                "description": "Whether the workflow schedule is enabled.",
                "computed": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "region": {
                "type": "string",
                "description": "The region where the workflow schedule is located.",
                "computed": true
              },
              "user_id": {
                "type": "string",
                "description": "The user ID that created the workflow schedule.",
                "computed": true
              },
              "workflow_id": {
                "type": "string",
                "description": "The ID of the workflow to which the schedule configuration belongs.",
                "required": true
              }
            },
            "block_types": {
              "policies": {
                "block": {
                  "attributes": {
                    "on_failure": {
                      "type": "string",
                      "description": "The policy action when the workflow execution fails.",
                      "computed": true
                    },
                    "on_running": {
                      "type": "string",
                      "description": "The policy action when the workflow is already running.",
                      "computed": true
                    }
                  },
                  "description": "schema:{\"Computed\":true};The scheduling policies of the workflow schedule."
                },
                "nesting_mode": "list",
                "max_items": 1
              }
            }
          }
        }
      }
    }
  }
}
