{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_css_log_setting": {
          "block": {
            "attributes": {
              "action": {
                "type": "string",
                "optional": true,
                "forcenew": true,
                "default": "base_log_collect"
              },
              "agency": {
                "type": "string",
                "optional": true
              },
              "auto_enabled": {
                "type": "bool",
                "computed": true
              },
              "base_path": {
                "type": "string",
                "optional": true
              },
              "bucket": {
                "type": "string",
                "optional": true
              },
              "cluster_id": {
                "type": "string",
                "required": true,
                "forcenew": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "index_prefix": {
                "type": "string",
                "optional": true
              },
              "keep_days": {
                "type": "number",
                "optional": true
              },
              "log_ingestion_create_at": {
                "type": "string",
                "computed": true
              },
              "log_ingestion_update_at": {
                "type": "string",
                "computed": true
              },
              "log_switch": {
                "type": "bool",
                "computed": true
              },
              "period": {
                "type": "string",
                "optional": true
              },
              "region": {
                "type": "string",
                "computed": true
              },
              "status": {
                "type": "string",
                "computed": true
              },
              "target_cluster_id": {
                "type": "string",
                "optional": true
              },
              "updated_at": {
                "type": "string",
                "computed": true
              }
            }
          },
          "product": {
            "short": "CSS",
            "name": "Cloud Search Service",
            "catalog": "Analytics",
            "name_cn": "云搜索服务",
            "catalog_cn": "大数据"
          }
        }
      }
    }
  }
}
