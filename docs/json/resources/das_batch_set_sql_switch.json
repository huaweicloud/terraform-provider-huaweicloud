{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_das_batch_set_sql_switch": {
          "block": {
            "attributes": {
              "engine_type": {
                "type": "string",
                "description": "The engine type of the instances.",
                "required": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_ids": {
                "type": [
                  "list",
                  "string"
                ],
                "description": "The list of instance IDs.",
                "required": true
              },
              "region": {
                "type": "string",
                "description": "The region where the SQL switch is located.",
