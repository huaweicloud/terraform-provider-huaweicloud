              },
              "retention_hours": {
                "type": "number",
                "description": "The retention hours of the SQL data.",
                "optional": true
              },
              "switch_on": {
                "type": "bool",
                "description": "Whether to enable the SQL switch.",
                "required": true
              },
              "switch_type": {
                "type": "string",
                "description": "The type of SQL switch to set.",
                "required": true
              }
            }
          },
          "product": {
            "short": "DAS",
            "name": "Data Admin Service",
            "catalog": "Databases",
            "name_cn": "数据管理服务",
            "catalog_cn": "数据库"
          }
        }
      }
    }
  }
}
