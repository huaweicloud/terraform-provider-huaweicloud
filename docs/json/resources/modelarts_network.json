{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_modelarts_network": {
          "block": {
            "attributes": {
              "cidr": {
                "type": "string",
                "description": "The CIDR of the network.",
                "required": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "name": {
                "type": "string",
                "description": "The name of the network.",
                "required": true
              },
              "region": {
                "type": "string",
                "description": "The region where the network is located.",
                "computed": true
              },
              "status": {
                "type": "string",
                "description": "The status of the network.",
                "computed": true
              },
              "subnet_id": {
                "type": "string",
                "description": "The ID of the subnet which the network is associated.",
                "computed": true
              },
              "workspace_id": {
                "type": "string",
                "description": "The ID of the workspace to which the network belongs.",
                "optional": true,
                "computed": true
              }
            },
            "block_types": {
              "peer_connections": {
                "block": {
                  "attributes": {
                    "subnet_id": {
                      "type": "string",
                      "description": "The ID of the subnet to which the peering connection belongs.",
                      "required": true
                    },
                    "vpc_id": {
                      "type": "string",
                      "description": "The ID of the VPC to which the peering connection belongs.",
                      "required": true
                    }
                  },
                  "description": "The list of peering connections that can be connected to the network."
                },
                "nesting_mode": "list"
              },
              "sfs_turbos": {
                "block": {
                  "attributes": {
                    "id": {
                      "type": "string",
                      "description": "The ID of the SFS Turbo to be associated.",
                      "required": true
                    },
                    "name": {
                      "type": "string",
                      "description": "The name of the SFS Turbo to be associated.",
                      "required": true
                    },
                    "uri": {
                      "type": "string",
                      "description": "The export location URI of the associated SFS Turbo in network.",
                      "computed": true
                    }
                  },
                  "description": "The list of SFS Turbos that can be connected to the network."
                },
                "nesting_mode": "list"
              }
            }
          },
          "product": {
            "short": "ModelArts",
            "name": "ModelArts",
            "catalog": "AI",
            "name_cn": "AI开发平台",
            "catalog_cn": "人工智能"
          }
        }
      }
    }
  }
}
