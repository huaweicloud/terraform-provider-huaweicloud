{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_modelarts_training_experiment": {
          "block": {
            "attributes": {
              "create_time": {
                "type": "string",
                "description": "The creation time of the training experiment, in RFC3339 format.",
                "computed": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
