{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_hss_custom_rule": {
          "block": {
            "attributes": {
              "agent_ids": {
                "type": [
                  "list",
                  "string"
                ],
                "optional": true
              },
              "agent_ids_attr": {
                "type": [
                  "list",
                  "string"
                ],
                "computed": true
              },
              "create_time": {
                "type": "number",
                "computed": true
              },
              "host_num": {
                "type": "number",
                "computed": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "is_all_host": {
                "type": "bool",
                "optional": true,
                "computed": true
              },
              "region": {
                "type": "string",
                "computed": true
              },
              "rule_name": {
                "type": "string",
                "required": true
              },
              "rule_status": {
                "type": "number",
                "optional": true,
                "default": 1
              },
              "update_time": {
                "type": "number",
                "computed": true
              }
            },
            "block_types": {
              "custom_rule_value_info": {
                "block": {
                  "attributes": {
                    "auto_block": {
                      "type": "number",
                      "required": true
                    },
                    "hash_type": {
                      "type": "string",
                      "required": true
                    },
                    "rule_type": {
                      "type": "string",
                      "required": true
                    },
                    "rule_values": {
                      "type": [
                        "list",
                        "string"
                      ],
                      "required": true
                    }
                  }
                },
                "nesting_mode": "list",
                "min_items": 1,
                "max_items": 1
              }
            }
          },
          "product": {
            "short": "HSS",
            "name": "Host Security Service",
            "catalog": "Security & Compliance",
            "name_cn": "企业主机安全",
            "catalog_cn": "安全与合规"
          }
        }
      }
    }
  }
}
