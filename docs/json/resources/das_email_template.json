                "optional": true
              },
              "updated_at": {
                "type": "string",
                "description": "The update time, in RFC3339 format.",
                "computed": true
              },
              "user_id": {
                "type": "string",
                "description": "The ID of the user who last modified the template.",
                "computed": true
              }
            }
          },
          "product": {
            "short": "DAS",
            "name": "Data Admin Service",
            "catalog": "Databases",
            "name_cn": "数据管理服务",
