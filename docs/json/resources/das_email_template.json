              },
              "email": {
                "type": "string",
                "description": "The email address.",
                "optional": true,
                "sensitive": true
              },
              "groups": {
                "type": [
                  "list",
                  "number"
                ],
                "description": "The list of instance group IDs.",
                "required": true
              },
              "health_rank": {
                "type": [
                  "list",
                  "string"
                ],
                "description": "The list of health ranks.",
                "required": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "inspection_time": {
                "type": "string",
                "description": "The diagnosis time.",
                "required": true
              },
              "name": {
                "type": "string",
                "description": "The name of the email template.",
                "required": true
              },
              "obs_bucket_name": {
                "type": "string",
