                      "rolbypassrls": "bool",
                      "rolcanlogin": "bool",
                      "rolconnlimit": "number",
                      "rolcreatedb": "bool",
                      "rolcreaterole": "bool",
                      "rolinherit": "bool",
                      "rolpassworddeadline": "string",
                      "rolreplication": "bool",
                      "rolsuper": "bool"
