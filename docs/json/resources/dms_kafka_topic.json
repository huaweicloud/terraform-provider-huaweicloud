{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_dms_kafka_topic": {
          "block": {
            "attributes": {
              "aging_time": {
                "type": "number",
                "description": "The aging time in hours.",
                "optional": true,
                "computed": true
              },
              "created_at": {
                "type": "string",
                "description": "The topic create time.",
                "computed": true
              },
              "description": {
                "type": "string",
                "description": "The description of the topic.",
                "optional": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_id": {
                "type": "string",
                "description": "The ID of the DMS kafka instance to which the topic belongs.",
                "required": true
              },
              "name": {
                "type": "string",
                "description": "The name of the topic.",
                "required": true
              },
              "new_partition_brokers": {
                "type": [
                  "set",
                  "number"
                ],
                "description": "The integers list of brokers for new partitions.",
                "optional": true
              },
              "partitions": {
                "type": "number",
                "description": "The partition number.",
                "required": true
              },
              "policies_only": {
                "type": "bool",
                "description": "Whether this policy is the default policy.",
                "computed": true
              },
              "region": {
                "type": "string",
                "description": "The region where the topic is located.",
                "computed": true
              },
              "replicas": {
                "type": "number",
                "description": "The replica number.",
                "optional": true,
                "computed": true
              },
              "sync_flushing": {
                "type": "bool",
                "description": "Whether to enable synchronous flushing.",
                "optional": true,
                "computed": true
              },
              "sync_replication": {
                "type": "bool",
                "description": "Whether to enable synchronous replication.",
                "optional": true,
                "computed": true
              },
              "type": {
                "type": "string",
                "description": "The topic type.",
                "computed": true
              }
            },
            "block_types": {
              "configs": {
                "block": {
                  "attributes": {
                    "name": {
                      "type": "string",
                      "description": "The configuration name.",
                      "required": true
                    },
                    "value": {
                      "type": "string",
                      "description": "The configuration value.",
                      "required": true
                    }
                  },
                  "description": "The other topic configurations."
                },
                "nesting_mode": "set"
              }
            }
          },
          "product": {
            "short": "Kafka",
            "name": "Distributed Message Service for Kafka",
            "catalog": "Middleware",
            "name_cn": "分布式消息服务 Kafka",
            "catalog_cn": "应用中间件"
          }
        }
      }
    }
  }
}
