{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_taurusdb_account": {
          "block": {
            "attributes": {
              "description": {
                "type": "string",
                "description": "Specifies the database user remarks.",
                "optional": true,
                "computed": true
              },
              "host": {
                "type": "string",
                "description": "Specifies the host IP address.",
                "optional": true,
                "computed": true,
                "forcenew": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_id": {
                "type": "string",
                "description": "Specifies the ID of the TaurusDB instance.",
                "required": true,
                "forcenew": true
              },
              "name": {
                "type": "string",
                "description": "Specifies the database username.",
                "required": true,
                "forcenew": true
              },
              "password": {
                "type": "string",
                "description": "Specifies the password of the database user.",
                "required": true,
                "sensitive": true
              },
              "region": {
                "type": "string",
                "computed": true
              }
            }
          }
        }
      }
    }
  }
}
