{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_rds_event_operate": {
          "block": {
            "attributes": {
              "id": {
                "type": "string",
                "computed": true
              },
              "operation_type": {
                "type": "string",
                "required": true
              },
              "region": {
                "type": "string",
                "computed": true
              },
              "results": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "error_code": "string",
                      "error_msg": "string",
                      "id": "string",
                      "instance_id": "string",
                      "job_id": "string",
                      "success": "bool"
                    }
                  ]
                ],
                "computed": true
              }
            },
            "block_types": {
              "event_instances": {
                "block": {
                  "attributes": {
                    "event_id": {
                      "type": "string",
