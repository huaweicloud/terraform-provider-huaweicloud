{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "resource_schemas": {
        "huaweicloud_taurusdb_sql_control_rule": {
          "block": {
            "attributes": {
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_id": {
                "type": "string",
                "description": "Specifies the ID of the TaurusDB instance.",
                "required": true,
                "forcenew": true
              },
              "max_concurrency": {
                "type": "number",
                "description": "Specifies the maximum number of concurrent SQL statements.",
                "required": true
              },
              "node_id": {
                "type": "string",
                "description": "Specifies ID of the TaurusDB node.",
                "required": true,
                "forcenew": true
              },
              "pattern": {
                "type": "string",
                "description": "Specifies the concurrency control rule of SQL statements.",
                "required": true,
                "forcenew": true
              },
              "region": {
                "type": "string",
                "computed": true
              },
              "sql_type": {
                "type": "string",
                "description": "Specifies SQL statement type.",
                "required": true,
                "forcenew": true
              }
            }
          }
        }
      }
    }
  }
}
