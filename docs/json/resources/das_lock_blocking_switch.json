              },
              "switch_on": {
                "type": "bool",
                "description": "Whether to enable the lock blocking switch.",
                "required": true
              }
            }
          },
          "product": {
            "short": "DAS",
            "name": "Data Admin Service",
            "catalog": "Databases",
            "name_cn": "数据管理服务",
            "catalog_cn": "数据库"
          }
        }
      }
    }
  }
