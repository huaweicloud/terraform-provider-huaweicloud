          "block": {
            "attributes": {
              "cluster_id": {
                "type": "string",
                "required": true
              },
              "completed": {
                "type": "bool",
                "computed": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_log": {
                "type": "string",
                "computed": true
              },
              "instance_name": {
                "type": "string",
                "required": true
              },
              "keyword": {
                "type": "string",
                "optional": true
              },
              "level": {
                "type": "string",
                "optional": true
              },
              "limit": {
                "type": "number",
                "optional": true
              },
              "log_list": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "content": "string",
                      "date": "string",
                      "level": "string"
