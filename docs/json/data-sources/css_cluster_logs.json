                "computed": true
              },
              "log_type": {
                "type": "string",
                "required": true
              },
              "region": {
                "type": "string",
                "computed": true
              },
              "time_index": {
                "type": "string",
                "optional": true
              },
              "type": {
                "type": "string",
                "computed": true
              }
            }
          },
          "product": {
            "short": "CSS",
            "name": "Cloud Search Service",
            "catalog": "Analytics",
            "name_cn": "云搜索服务",
            "catalog_cn": "大数据"
          }
        }
      }
    }
  }
}
