{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_drs_progress_data": {
          "block": {
            "attributes": {
              "create_time": {
                "type": "string",
                "computed": true
              },
              "flow_compare_data": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "dst_db": "string",
                      "dst_tb": "string",
                      "progress": "number",
                      "src_db": "string",
                      "src_tb": "string"
                    }
                  ]
                ],
                "computed": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "job_id": {
                "type": "string",
                "required": true
              },
              "region": {
                "type": "string",
                "computed": true
              },
              "type": {
                "type": "string",
                "required": true
              }
            }
          },
          "product": {
            "short": "DRS",
            "name": "Data Replication Service",
            "catalog": "Databases",
            "name_cn": "数据复制服务",
            "catalog_cn": "数据库"
          }
        }
      }
    }
  }
}
