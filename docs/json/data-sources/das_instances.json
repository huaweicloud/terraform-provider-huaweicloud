{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_das_instances": {
          "block": {
            "attributes": {
              "datastore_type": {
                "type": "string",
                "description": "The type of the database.",
                "required": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "instances": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "charge_flag": "bool",
                      "cpu": "number",
                      "deadlock_flag": "bool",
                      "engine_type": "string",
                      "full_sql_flag": "bool",
                      "id": "string",
                      "ip": "string",
                      "lock_blocking_flag": "bool",
                      "login_flag": "bool",
                      "mem": "number",
                      "name": "string",
                      "port": "number",
                      "slow_sql_flag": "bool",
                      "status": "string",
                      "version": "string"
                    }
                  ]
                ],
                "description": "The list of instances that matched filter parameters.",
                "computed": true
              },
              "region": {
                "type": "string",
                "description": "The region where the instances are located.",
                "computed": true
              }
            }
          },
          "product": {
            "short": "DAS",
            "name": "Data Admin Service",
            "catalog": "Databases",
            "name_cn": "数据管理服务",
            "catalog_cn": "数据库"
          }
        }
      }
    }
  }
}
