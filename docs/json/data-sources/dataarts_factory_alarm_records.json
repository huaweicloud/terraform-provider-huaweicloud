{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_dataarts_factory_alarm_records": {
          "block": {
            "attributes": {
              "end_time": {
                "type": "string",
                "description": "The end time of the alarm records, in RFC3339 format.",
                "optional": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "records": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "alarm_time": "string",
                      "job_id": "number",
                      "job_name": "string",
                      "plan_time": "string",
                      "remind_type": "number",
                      "schedule_type": "number",
                      "send_msg": "string",
                      "send_status": "number"
                    }
                  ]
                ],
                "description": "The list of alarm records.",
                "computed": true
              },
              "region": {
                "type": "string",
                "description": "The region where the alarm records are located.",
                "computed": true
              },
              "start_time": {
                "type": "string",
                "description": "The start time of the alarm records, in RFC3339 format.",
                "optional": true
              },
              "workspace": {
                "type": "string",
                "description": "The workspace ID.",
                "optional": true
              }
            }
          },
          "product": {
            "short": "DataArtsStudio",
            "name": "DataArts Studio",
            "catalog": "Analytics",
            "name_cn": "数据治理中心",
            "catalog_cn": "大数据"
          }
        }
      }
    }
  }
}
