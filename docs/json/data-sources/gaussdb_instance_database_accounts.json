                      "lock_status": "bool",
                      "memberof": "string",
                      "name": "string"
                    }
                  ]
                ],
                "computed": true
              }
            }
          },
          "product": {
            "short": "GaussDB",
            "name": "GaussDB",
            "catalog": "Databases",
            "name_cn": "云数据库 GaussDB",
            "catalog_cn": "数据库"
