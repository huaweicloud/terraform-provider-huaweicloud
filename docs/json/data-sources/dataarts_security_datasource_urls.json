{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_dataarts_security_datasource_urls": {
          "block": {
            "attributes": {
              "cluster_id": {
                "type": "string",
                "description": "The ID of the cluster.",
                "optional": true
              },
              "datasource_type": {
                "type": "string",
                "description": "The type of the datasource.",
                "optional": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "parent_permission_set_id": {
                "type": "string",
                "description": "The ID of the parent permission set.",
                "optional": true
              },
              "region": {
                "type": "string",
                "description": "The region where the datasource urls are located.",
                "computed": true
              },
              "urls": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "contains": "bool",
                      "name": "string"
                    }
                  ]
                ],
                "description": "The list of datasource urls that matched filter parameters.",
                "computed": true
              },
              "workspace_id": {
                "type": "string",
                "description": "The ID of the workspace to which the datasource urls belong.",
                "required": true
              }
            }
          },
          "product": {
            "short": "DataArtsStudio",
            "name": "DataArts Studio",
            "catalog": "Analytics",
            "name_cn": "数据治理中心",
            "catalog_cn": "大数据"
          }
        }
      }
    }
  }
}
