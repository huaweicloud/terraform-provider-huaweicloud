                "type": "string",
                "computed": true
              },
              "user_details": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "databases": [
                        "list",
                        "string"
                      ],
                      "ddl": "number",
                      "dml": "number",
                      "user_name": "string"
                    }
                  ]
                ],
                "computed": true
              },
              "user_name": {
                "type": "string",
                "optional": true
              }
            }
          }
        }
      }
    }
  }
}
