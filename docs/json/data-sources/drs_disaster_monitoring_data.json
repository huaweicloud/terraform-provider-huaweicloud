                            "node_offset": "string",
                            "node_volume_in_gb": "number",
                            "sr_delay": "number",
                            "sr_offset": "string",
                            "src_io": "string",
                            "src_normal": "bool",
                            "src_rps": "string",
                            "trans_in_mb": "string",
                            "trans_lines": "string",
                            "volume_used_in_gb": "string"
                          }
                        ]
                      ],
                      "id": "string"
                    }
                  ]
