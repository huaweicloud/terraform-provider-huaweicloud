                        [
                          "object",
                          {
                            "biz_id": "string",
                            "biz_info": "string",
                            "biz_type": "string",
                            "biz_version": "string",
                            "created_at": "string",
                            "id": "string",
                            "status": "string",
                            "updated_at": "string"
                          }
                        ]
                      ],
                      "status": "string",
                      "updated_at": "string",
                      "updated_by": "string",
                      "values": [
                        "list",
                        [
                          "object",
                          {
                            "created_at": "string",
                            "created_by": "string",
                            "directory_id": "string",
                            "fd_id": "string",
                            "fd_name": "string",
                            "fd_value": "string",
                            "id": "string",
                            "row_id": "string",
