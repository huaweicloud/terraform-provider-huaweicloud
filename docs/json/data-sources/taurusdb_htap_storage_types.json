{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_taurusdb_htap_storage_types": {
          "block": {
            "attributes": {
              "database": {
                "type": "string",
                "required": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "region": {
                "type": "string",
                "computed": true
              },
              "storage_type": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "az_status": [
                        "map",
                        "string"
                      ],
                      "min_volume_size": "number",
                      "name": "string"
                    }
                  ]
                ],
                "computed": true
              },
              "version_name": {
                "type": "string",
                "required": true
              }
            }
          }
        }
      }
    }
  }
}
