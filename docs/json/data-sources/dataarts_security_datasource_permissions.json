          "block": {
            "attributes": {
              "datasource_permissions": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "datasource_type": "string",
                      "permission_actions": [
                        "list",
                        "string"
                      ],
                      "permission_types": [
                        "list",
                        "string"
                      ]
                    }
                  ]
                ],
                "description": "The list of datasource configurable permissions.",
