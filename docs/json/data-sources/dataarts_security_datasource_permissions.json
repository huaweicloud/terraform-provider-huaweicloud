                "computed": true
              },
              "workspace_id": {
                "type": "string",
                "description": "The ID of the workspace to which the datasource permissions belong.",
                "required": true
              }
            }
          },
          "product": {
            "short": "DataArtsStudio",
            "name": "DataArts Studio",
            "catalog": "Analytics",
            "name_cn": "数据治理中心",
            "catalog_cn": "大数据"
          }
        }
      }
    }
  }
}
