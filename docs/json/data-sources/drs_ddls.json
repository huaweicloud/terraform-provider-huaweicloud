              },
              "job_id": {
                "type": "string",
                "required": true
              },
              "region": {
                "type": "string",
                "computed": true
              },
              "start_seq_no": {
                "type": "string",
                "optional": true
              },
              "status": {
                "type": "string",
                "optional": true
              }
            }
          },
          "product": {
            "short": "DRS",
            "name": "Data Replication Service",
            "catalog": "Databases",
            "name_cn": "数据复制服务",
            "catalog_cn": "数据库"
