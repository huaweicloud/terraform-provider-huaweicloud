                "type": "string",
                "optional": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_id": {
                "type": "string",
                "required": true
              },
              "region": {
                "type": "string",
                "computed": true
              },
              "restorable_time_periods": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "end_time": "number",
                      "start_time": "number"
                    }
                  ]
                ],
                "computed": true
              },
              "start_time": {
                "type": "string",
                "optional": true
              }
            }
          },
          "product": {
            "short": "GaussDBforNoSQL",
            "name": "GeminiDB",
            "catalog": "Databases",
            "name_cn": "云数据库 GeminiDB",
            "catalog_cn": "数据库"
          }
        }
      }
    }
  }
}
