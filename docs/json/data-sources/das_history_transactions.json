{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_das_history_transactions": {
          "block": {
            "attributes": {
              "datastore_type": {
                "type": "string",
                "description": "The database type.",
                "required": true
              },
              "end_time": {
                "type": "string",
                "description": "The end time of the query range, in RFC3339 format.",
                "required": true
              },
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_id": {
                "type": "string",
                "description": "The ID of the database instance.",
                "required": true
              },
              "last_sec_max": {
                "type": "number",
                "description": "The maximum duration of the transaction, in seconds.",
                "optional": true
              },
              "last_sec_min": {
                "type": "number",
                "description": "The minimum duration of the transaction, in seconds.",
                "optional": true
              },
              "order_by": {
                "type": "string",
                "description": "The sort order.",
                "optional": true
              },
              "order_field": {
                "type": "string",
                "description": "The field used for sorting.",
                "optional": true
              },
              "region": {
                "type": "string",
                "description": "The region where the DAS history transactions are located.",
                "computed": true
              },
              "start_time": {
                "type": "string",
                "description": "The start time of the query range, in RFC3339 format.",
                "required": true
              },
              "transactions": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "collect_time": "string",
                      "detail": "string",
                      "hold_locks": "number",
                      "last_sec": "number",
                      "occurrence_time": "string",
                      "wait_locks": "number"
                    }
                  ]
                ],
                "description": "The list of history transactions that matched the filter parameters.",
                "computed": true
              }
            }
          },
          "product": {
            "short": "DAS",
            "name": "Data Admin Service",
            "catalog": "Databases",
            "name_cn": "数据管理服务",
            "catalog_cn": "数据库"
          }
        }
      }
    }
  }
}
