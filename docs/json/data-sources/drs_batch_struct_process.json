{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_drs_batch_struct_process": {
          "block": {
            "attributes": {
              "id": {
                "type": "string",
                "computed": true
              },
              "job_ids": {
                "type": [
                  "list",
                  "string"
                ],
                "required": true
              },
              "region": {
                "type": "string",
                "computed": true
              },
              "results": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "database_info": [
                        "list",
                        [
                          "object",
                          {
                            "disaster_recovery_database": "string",
                            "service_database": "string"
                          }
                        ]
                      ],
                      "error_code": "string",
                      "error_message": "string",
                      "job_id": "string",
                      "struct_process": [
                        "list",
                        [
                          "object",
                          {
                            "create_time": "string",
                            "result": [
                              "list",
                              [
                                "object",
                                {
                                  "dst_count": "number",
                                  "end_time": "number",
                                  "src_count": "number",
                                  "start_time": "number",
                                  "status": "number",
                                  "type": "string"
                                }
                              ]
                            ]
                          }
                        ]
                      ]
                    }
                  ]
                ],
                "computed": true
              }
            }
          },
          "product": {
            "short": "DRS",
            "name": "Data Replication Service",
            "catalog": "Databases",
            "name_cn": "数据复制服务",
            "catalog_cn": "数据库"
          }
        }
      }
    }
  }
}
