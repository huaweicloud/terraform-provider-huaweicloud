{
  "provider_schemas": {
    "huaweicloud/huaweicloud": {
      "data_source_schemas": {
        "huaweicloud_das_sql_limit_rules": {
          "block": {
            "attributes": {
              "id": {
                "type": "string",
                "computed": true
              },
              "instance_id": {
                "type": "string",
                "description": "The ID of the instance to which the SQL limit rules belong.",
                "required": true
              },
              "region": {
                "type": "string",
                "description": "The region where the SQL limit rules are located.",
                "computed": true
              },
              "rules": {
                "type": [
                  "list",
                  [
                    "object",
                    {
                      "id": "string",
                      "max_concurrency": "number",
                      "max_waiting": "number",
                      "pattern": "string",
                      "sql_type": "string"
                    }
                  ]
                ],
                "description": "The list of SQL limit rules that matched filter parameters.",
                "computed": true
              }
            }
          },
          "product": {
            "short": "DAS",
            "name": "Data Admin Service",
            "catalog": "Databases",
            "name_cn": "数据管理服务",
            "catalog_cn": "数据库"
          }
        }
      }
    }
  }
}
